# auto_trade_bot — User Configuration
# ==========================================
# Author  : K R HARI PRAJWAL
# License : MIT
#
# Copy this file to user.cfg and fill in your credentials.

[auto_trade_bot_config]

# ─── BROKER ────────────────────────────────────────────────────────────────────
# Options: angel_one | zerodha | upstox | dhan | fyers | groww
broker = angel_one

# Angel One credentials
api_key        = YOUR_ANGEL_ONE_API_KEY
client_id      = YOUR_CLIENT_ID
password       = YOUR_LOGIN_PASSWORD
totp_secret    = YOUR_TOTP_BASE32_SECRET

# Zerodha credentials (if using zerodha)
# api_key        = YOUR_ZERODHA_API_KEY
# api_secret     = YOUR_ZERODHA_API_SECRET
# access_token   = YOUR_DAILY_ACCESS_TOKEN   ← must refresh manually every day

# Upstox credentials (if using upstox)
# api_key        = YOUR_UPSTOX_API_KEY
# api_secret     = YOUR_UPSTOX_API_SECRET
# access_token   = YOUR_UPSTOX_ACCESS_TOKEN
# redirect_uri   = http://localhost

# Dhan credentials (if using dhan)
# client_id      = YOUR_DHAN_CLIENT_ID
# access_token   = YOUR_DHAN_ACCESS_TOKEN

# Fyers credentials (if using fyers)
# client_id      = YOUR_FYERS_CLIENT_ID
# access_token   = YOUR_FYERS_ACCESS_TOKEN

# Groww Pro credentials (if using groww)
# Note: Groww charges ZERO brokerage on delivery — cheapest for CNC trading!
# Get your API access from: https://groww.in/trading-api
# client_id      = YOUR_GROWW_CLIENT_ID
# access_token   = YOUR_GROWW_ACCESS_TOKEN


# ─── MARKET ────────────────────────────────────────────────────────────────────
# Exchange: NSE | BSE | BOTH
exchange = NSE

# trade_type: intraday (auto square-off 3:20 PM) | delivery (hold overnight)
trade_type = intraday

# Market hours (IST). Bot will not trade outside these hours.
market_open_time  = 09:15
market_close_time = 15:20

# If intraday position is at a loss near close, how much loss is OK to carry as delivery?
# Example: 2.0 means if down less than 2%, convert to delivery instead of forced square-off
max_loss_to_carry_delivery_pct = 2.0


# ─── SCOUTING & FEES ───────────────────────────────────────────────────────────
# How often to scan for a trade (seconds). Lower = faster reaction, more API calls.
scout_sleep_time = 10

# Minimum gain % needed to trigger a trade.
# This MUST exceed your total round-trip brokerage cost to be profitable.
#
#  Intraday (MIS) fee breakdown — ALL brokers (round-trip ~0.13%):
#    Brokerage ₹20/order + STT 0.025% sell + NSE 0.007% + GST + SEBI + Stamp
#    → Set scout_margin >= 0.3  (leaves ~0.17% profit per trade)
#
#  Delivery (CNC) fee breakdown — Angel One / Zerodha / Upstox / Dhan / Fyers (round-trip ~0.32%):
#    Brokerage ₹20/order + STT 0.1% BOTH sides + NSE + GST + SEBI + Stamp
#    → Set scout_margin >= 0.8  (leaves ~0.48% profit per trade)
#
#  Delivery (CNC) fee breakdown — GROWW only (round-trip ~0.21%  ← cheaper!):
#    Brokerage ZERO ✅ + STT 0.1% BOTH sides + NSE + GST + SEBI + Stamp
#    → Set scout_margin >= 0.5  (leaves ~0.29% profit per trade)
#
scout_margin = 0.3

# use_margin: yes = scout_margin acts as direct % threshold (recommended)
#             no  = multiplier mode (advanced)
use_margin = yes

# Scout multiplier (only used if use_margin = no)
scout_multiplier = 5

# Keep scout history for this many hours (for DB cleanup)
hour_to_keep_scout_history = 1


# ─── ORDERS ────────────────────────────────────────────────────────────────────
# How long to wait for an order to fill before cancelling (seconds)
sell_timeout = 30
buy_timeout  = 30


# ─── STRATEGY ──────────────────────────────────────────────────────────────────
strategy = default

# Which stock to hold when the bot starts for the first time.
# Leave empty to pick randomly from supported_stock_list.
# current_stock = RELIANCE
